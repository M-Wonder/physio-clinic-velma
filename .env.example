# ================================================================
# PhysioClinic — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ================================================================

# --- Django core ---
SECRET_KEY=replace-with-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_ENV=development

# --- PostgreSQL ---
POSTGRES_DB=physio_clinic
POSTGRES_USER=physio_user
POSTGRES_PASSWORD=choose-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT tokens ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Email ---
# Development: console prints emails to terminal (no SMTP needed)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Production: swap to smtp.EmailBackend and fill fields below
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-clinic-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=PhysioClinic <noreply@physio.clinic>

# --- Twilio SMS (optional — leave blank to disable SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- PII Encryption ---
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-generated-fernet-key

# --- Frontend ---
VITE_API_URL=http://localhost:8000/api
VITE_APP_NAME=PhysioClinic

# --- Files ---
MEDIA_ROOT=/app/media
MAX_UPLOAD_SIZE_MB=20

# --- Clinic info (used in notification emails) ---
CLINIC_NAME=PhysioClinic
CLINIC_PHONE=+1-555-PHYSIO
CLINIC_EMAIL=info@physio.clinic
CLINIC_ADDRESS=123 Health Avenue, Medical District

# --- Appointment rules ---
APPOINTMENT_DURATION_MINUTES=60
BOOKING_ADVANCE_DAYS=30
CANCELLATION_NOTICE_HOURS=24
